# === Gemini AI ===
GEMINI_API_KEY=your_gemini_api_key

# === YouTube Data API v3 ===
YOUTUBE_API_KEY=your_youtube_api_key

# === Reddit API ===
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=FoodTrendBot/2.0

# === X (Twitter) API v2 ===
X_BEARER_TOKEN=your_x_bearer_token

# === Naver Open API ===
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# === LINE Works Bot API v2.0 ===
LINEWORKS_BOT_ID=your_bot_id
LINEWORKS_CLIENT_ID=your_client_id
LINEWORKS_CLIENT_SECRET=your_client_secret
LINEWORKS_SERVICE_ACCOUNT=your_service_account@your_domain
LINEWORKS_PRIVATE_KEY=/path/to/private_key.key
LINEWORKS_USER_ID=your_user_id@your_domain

# === LINE Messaging API (フォールバック) ===
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_USER_ID=your_line_user_id

# === Notion API ===
NOTION_TOKEN=your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# === Google Custom Search API (ポッドキャスト画像ページ用) ===
GOOGLE_CSE_API_KEY=your_google_cse_api_key
GOOGLE_CSE_ID=your_custom_search_engine_id
